{
  "schemaVersion": 1,
  "id": "ccspeakercodecs",
  "version": "${version}",
  "name": "CCSpeakerCodecs",
  "description": "Adds a collection of alternate transit codecs for CC: Tweaked speakers to improve audio quality.",
  "authors": [
    "JackMacWindows"
  ],
  "contact": {
    "homepage": "https://github.com/MCJack123/CCSpeakerCodecs"
  },
  "license": "MPL-2.0",
  "icon": "assets/ccspeakercodecs/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "cc.craftospc.ccspeakercodecs.fabric.CCSpeakerCodecsFabric"
    ],
    "client": [
      "cc.craftospc.ccspeakercodecs.fabric.client.CCSpeakerCodecsFabricClient"
    ]
  },
  "mixins": [
    "ccspeakercodecs.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.0",
    "minecraft": "1.20.1",
    "java": ">=17",
    "fabric-api": "*",
    "computercraft": ">=1.110.0"
